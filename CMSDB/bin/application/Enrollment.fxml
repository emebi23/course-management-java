<AnchorPane prefHeight="623.0" prefWidth="560.0" style="-fx-background-color:linear-gradient(from 0% 0% to 100% 100%, #84fab0, #8fd3f4);" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.Enrollmentcontroller">
