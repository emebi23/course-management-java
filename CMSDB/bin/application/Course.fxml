<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="388.0" prefWidth="416.0" style="-fx-background-color: linear-gradient(to right, #89f7fe, #66a6ff);" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.Coursecontroller">
   <children>
    <VBox alignment="CENTER" layoutX="160.0" layoutY="100.0" prefHeight="157.0" prefWidth="231.0" spacing="15">
         
        
        
      <TextField fx:id="codeField" layoutX="143.0" layoutY="96.0" prefHeight="26.0" prefWidth="282.0" />
      <TextField fx:id="titleField" layoutX="143.0" layoutY="140.0" />
      <TextField fx:id="instructorField" layoutX="144.0" layoutY="185.0" />
      </VBox>
   <Label layoutX="39.0" layoutY="131.0" prefHeight="27.0" prefWidth="77.0" text="Course Code">
      <font>
         <Font size="13.0" />
      </font>
      </Label>
   <Label layoutX="36.0" layoutY="172.0" prefHeight="27.0" prefWidth="84.0" text="Course Name">
      <font>
         <Font size="13.0" />
      </font>
      </Label>
   <Label layoutX="46.0" layoutY="213.0" prefHeight="27.0" prefWidth="84.0" text="Instructor">
      <font>
         <Font size="13.0" />
      </font>
      </Label>
   <Button fx:id="addButton" layoutX="132.0" layoutY="281.0" mnemonicParsing="false" onAction="#handleAdd" style="-fx-background-color:white;" text="Add">
      <font>
         <Font name="Arial Black" size="13.0" />
      </font>
      </Button>
   <Button layoutX="-10.0" layoutY="4.0" mnemonicParsing="false" onAction="#goHome" style="-fx-background-color: white;" text="Back to Home">
      <font>
         <Font name="Arial Black" size="13.0" />
      </font>
   </Button>
   <Label alignment="CENTER" layoutX="46.0" layoutY="49.0" prefHeight="18.0" prefWidth="218.0" text="COURSE REGISTRATION" textFill="#0d1b2a">
      <font>
         <Font name="Arial Black" size="13.0" />
      </font>
   </Label>
   </children>
</AnchorPane>
