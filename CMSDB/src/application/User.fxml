<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #fbc2eb, #a6c1ee);" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/23.0.1" fx:controller="application.Usercontroller">

    <top>
        <Label style="-fx-font-size: 20px;" text="User Management" BorderPane.alignment="CENTER" />
    </top>

    <center>
        <VBox prefHeight="176.0" prefWidth="576.0" spacing="10" style="-fx-background-radius: 20; -fx-padding: 20; -fx-background-color: rgba(255,255,255,0.8);">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <HBox spacing="10">
                <Label text="Username:" />
                <TextField fx:id="tfUsername" prefHeight="26.0" prefWidth="170.0" />
            </HBox>

            <HBox spacing="10">
                <Label text="Password:" />
                <PasswordField fx:id="tfPassword" prefHeight="26.0" prefWidth="174.0" />
            </HBox>

            <HBox spacing="10">
                <Label text="Role:" />
                <ComboBox fx:id="cbRole" prefHeight="26.0" prefWidth="54.0" />
            </HBox>

            <HBox spacing="10">
                <Button onAction="#addUser" text="Add" />
                <Button onAction="#updateUser" text="Update" />
                <Button onAction="#deleteUser" text="Delete" />
            </HBox>
        </VBox>
    </center>

    <bottom>
        <TableView fx:id="userTable" prefHeight="370.0" prefWidth="576.0">
            <columns>
                <TableColumn fx:id="colId" prefWidth="136.79998779296875" text="ID" />
                <TableColumn fx:id="colUsername" prefWidth="140.800048828125" text="Username" />
                <TableColumn fx:id="colPassword" prefWidth="152.7999267578125" text="Password" />
                <TableColumn fx:id="colRole" prefWidth="153.5999755859375" text="Role" />
            </columns>
        </TableView>
    </bottom>



</BorderPane>
