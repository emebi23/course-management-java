<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="559.0" prefWidth="635.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.Studentcontroller">
    <children>
    
    <VBox alignment="CENTER" spacing="15" style="-fx-background-color: linear-gradient(to right, #74ebd5, #ACB6E5); -fx-background-radius: 12; -fx-padding: 20; " AnchorPane.bottomAnchor="40.0" AnchorPane.leftAnchor="60.0" AnchorPane.rightAnchor="60.0" AnchorPane.topAnchor="40.0">
      <Label alignment="CENTER" layoutX="67.0" layoutY="34.0" prefHeight="26.0" prefWidth="308.0" text="Student Registration Form" textFill="#1B1B2F">
         <font>
            <Font name="Algerian" size="14.0" />
         </font>
      </Label>
              
        <Label layoutX="30.0" layoutY="87.0" prefHeight="18.0" prefWidth="78.0" text="Student ID:">
         <font>
            <Font name="Arial Black" size="11.0" />
         </font></Label>
        <TextField fx:id="idField" layoutX="125.0" layoutY="83.0" />

        <Label layoutX="30.0" layoutY="129.0" prefHeight="18.0" prefWidth="50.0" text="Name:">
         <font>
            <Font name="Arial Black" size="11.0" />
         </font></Label>
        <TextField fx:id="nameField" layoutX="125.0" layoutY="125.0" />

        <Label layoutX="30.0" layoutY="170.0" prefHeight="18.0" prefWidth="50.0" text="Email:">
         <font>
            <Font name="Arial Black" size="11.0" />
         </font></Label>
        <TextField fx:id="emailField" layoutX="125.0" layoutY="167.0" />

        <Button fx:id="addButton" layoutX="77.0" layoutY="241.0" onAction="#handleAdd" style="-fx-background-color:white;" text="Add">
         <font>
            <Font name="Arial Black" size="12.0" />   
         </font></Button>
        <Button fx:id="updateButton" layoutX="147.0" layoutY="241.0" onAction="#handleUpdate" style="-fx-background-color: white;" text="Update">
         <font>
            <Font name="Arial Black" size="12.0" />
         </font></Button>
        <Button fx:id="deleteButton" layoutX="245.0" layoutY="241.0" onAction="#handleDelete" style="-fx-background-color:white;" text="Delete">
         <font>
            <Font name="Arial Black" size="12.0" />
         </font></Button>
        <Button onAction="#goHome" style="-fx-background-color: white;" text="Back to Home">
         <font>
            <Font name="Arial Black" size="12.0" />
         </font></Button>
        </VBox>
    </children>
</AnchorPane>
