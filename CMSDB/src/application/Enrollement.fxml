<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="623.0" prefWidth="560.0" style="-fx-background-color: tan;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.Enrollmentcontroller">
   <children>
      <Label alignment="CENTER" layoutX="82.0" layoutY="39.0" prefHeight="22.0" prefWidth="183.0" text="ENROLLMENT FORM">
         <font>
            <Font name="Arial Black" size="14.0" />
         </font>
      </Label>
      <Label layoutX="50.0" layoutY="102.0" text="Student ID:">
         <font>
            <Font name="Arial Black" size="12.0" />
         </font></Label>
      <TextField fx:id="studentIdField" layoutX="150.0" layoutY="98.0" />

      <Label layoutX="44.0" layoutY="147.0" text="Course Code:">
         <font>
            <Font name="Arial Black" size="12.0" />
         </font></Label>
      <TextField fx:id="courseCodeField" layoutX="150.0" layoutY="143.0" />

      <Label layoutX="73.0" layoutY="190.0" prefHeight="22.0" prefWidth="46.0" text="Grade: ">
         <font>
            <Font name="Ebrima Bold" size="13.0" />
         </font></Label>
      <TextField fx:id="gradeField" layoutX="150.0" layoutY="189.0" />



      <Button fx:id="enrollButton" layoutX="158.0" layoutY="244.0" onAction="#handleEnroll" style="-fx-background-color: white;" text="Enroll">
         <font>
            <Font name="System Bold" size="13.0" />
         </font></Button>
      <Button onAction="#goHome" text="Back to Home">
         <font>
            <Font name="System Bold" size="12.0" />
         </font></Button>
      <TableView fx:id="tableEnrollment" layoutX="112.0" layoutY="353.0" prefHeight="200.0" prefWidth="306.0">
        <columns>
          <TableColumn fx:id="colId" prefWidth="75.0" text="ID" />
          <TableColumn fx:id="colStudentid" prefWidth="75.0" text="Student ID" />
            <TableColumn fx:id="colCoursecode" prefWidth="75.0" text="Course Code" />
            <TableColumn fx:id="colGrade" prefWidth="75.0" text="Grade" />
        </columns>
      </TableView>
      
   </children>
</AnchorPane>
