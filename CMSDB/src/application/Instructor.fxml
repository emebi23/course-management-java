<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="381.0" prefWidth="478.0" style="-fx-background-color:linear-gradient(to right, #74ebd5, #ACB6E5);" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.Instructorcontroller">
    <children>
    <VBox alignment="CENTER" spacing="15">
     <Button layoutX="1.0" layoutY="1.0" onAction="#goHome" text="Back to Home">
      <font>
         <Font name="Arial Black" size="12.0" />
      </font>
      </Button>
        </VBox>
<Label alignment="CENTER" layoutX="160.0" layoutY="26.0" prefHeight="26.0" prefWidth="150.0" style="-fx-background-color: lavender;" text="Instructor Form" textFill="#4a2c2a">
   <font>
      <Font name="Elephant Italic" size="14.0" />
   </font>
</Label>
  <TextField fx:id="nameField" layoutX="135.0" layoutY="75.0" prefHeight="26.0" prefWidth="202.0" />
  <TextField fx:id="departmentField" layoutX="135.0" layoutY="168.0" prefHeight="26.0" prefWidth="202.0" />
  <TextField fx:id="idField" layoutX="133.0" layoutY="118.0" prefHeight="26.0" prefWidth="202.0" />
  <Button fx:id="deleteButton" layoutX="276.0" layoutY="257.0" onAction="#handleDelete" style="-fx-background-color: white;" text="Delete" />

  <Button fx:id="addButton" layoutX="89.0" layoutY="257.0" onAction="#handleAdd" style="-fx-background-color: white;" text="Add" />
  <Button fx:id="updateButton" layoutX="179.0" layoutY="257.0" onAction="#handleUpdate" style="-fx-background-color: white;" text="Update" />

  <Label layoutX="21.0" layoutY="168.0" text="Department:" />
  <Label layoutX="20.0" layoutY="123.0" text="Instructor ID:" />

  <Label layoutX="21.0" layoutY="79.0" prefHeight="18.0" prefWidth="66.0" text="Name:" />
    </children>
</AnchorPane>
