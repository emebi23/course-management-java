<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane style="-fx-background-color: #f0f2f5;"
    xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="application.Studentcontroller">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: linear-gradient(to right, #1a1a2e, #0f3460);
                     -fx-padding: 0 20 0 0;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 8, 0, 0, 3);">
            <HBox alignment="CENTER" spacing="10" style="-fx-background-color: #e96c50; -fx-padding: 16 24;">
                <Label text="👤" style="-fx-font-size: 20px;" />
                <Label text="Student Management" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" />
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button text="🏠 Back to Home" onAction="#goHome"
                style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white;
                       -fx-background-radius: 6; -fx-font-size: 13px; -fx-padding: 8 16;
                       -fx-cursor: hand; -fx-border-color: transparent;" />
        </HBox>
    </top>

    <center>
        <VBox spacing="14" style="-fx-padding: 18;">

            <!-- Form Card -->
            <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-padding: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 3);">
                <Label text="Student Information" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;" />
                <HBox spacing="14" alignment="CENTER_LEFT">
                    <VBox spacing="4">
                        <Label text="Student ID" style="-fx-font-size: 11px; -fx-text-fill: #666;" />
                        <TextField fx:id="idField" prefWidth="130"
                            style="-fx-background-color:white;-fx-border-color:#d0d0d0;-fx-border-radius:8;-fx-background-radius:8;-fx-border-width:1;-fx-padding:8 10;-fx-font-size:13px;" />
                    </VBox>
                    <VBox spacing="4">
                        <Label text="Full Name" style="-fx-font-size: 11px; -fx-text-fill: #666;" />
                        <TextField fx:id="nameField" prefWidth="170"
                            style="-fx-background-color:white;-fx-border-color:#d0d0d0;-fx-border-radius:8;-fx-background-radius:8;-fx-border-width:1;-fx-padding:8 10;-fx-font-size:13px;" />
                    </VBox>
                    <VBox spacing="4">
                        <Label text="Gender" style="-fx-font-size: 11px; -fx-text-fill: #666;" />
                        <ComboBox fx:id="genderCombo" prefWidth="110"
                            style="-fx-background-color:white;-fx-border-color:#d0d0d0;-fx-border-radius:8;-fx-background-radius:8;-fx-border-width:1;-fx-font-size:13px;" />
                    </VBox>
                    <VBox spacing="4">
                        <Label text="Email" style="-fx-font-size: 11px; -fx-text-fill: #666;" />
                        <TextField fx:id="emailField" prefWidth="190"
                            style="-fx-background-color:white;-fx-border-color:#d0d0d0;-fx-border-radius:8;-fx-background-radius:8;-fx-border-width:1;-fx-padding:8 10;-fx-font-size:13px;" />
                    </VBox>
                    <VBox spacing="4">
                        <Label text="Phone" style="-fx-font-size: 11px; -fx-text-fill: #666;" />
                        <TextField fx:id="phoneField" prefWidth="130"
                            style="-fx-background-color:white;-fx-border-color:#d0d0d0;-fx-border-radius:8;-fx-background-radius:8;-fx-border-width:1;-fx-padding:8 10;-fx-font-size:13px;" />
                    </VBox>
                </HBox>
                <HBox spacing="14" alignment="CENTER_LEFT">
                    <VBox spacing="4">
                        <Label text="Class / Section" style="-fx-font-size: 11px; -fx-text-fill: #666;" />
                        <ComboBox fx:id="classCombo" prefWidth="360"
                            promptText="Select class..."
                            style="-fx-background-color:white;-fx-border-color:#d0d0d0;-fx-border-radius:8;-fx-background-radius:8;-fx-border-width:1;-fx-font-size:13px;" />
                    </VBox>
                </HBox>
            </VBox>

            <!-- Toolbar -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="🔍  Search by ID or Name..." prefWidth="260"
                    style="-fx-background-color:white;-fx-border-color:#d0d0d0;-fx-border-radius:8;-fx-background-radius:8;-fx-border-width:1;-fx-padding:8 12;-fx-font-size:13px;" />
                <Button text="Search" onAction="#handleSearch"
                    style="-fx-background-color:#2980b9;-fx-text-fill:white;-fx-background-radius:8;-fx-font-size:13px;-fx-padding:10 18;-fx-cursor:hand;-fx-border-color:transparent;" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="➕ Add"    onAction="#handleAdd"    style="-fx-background-color:#27ae60;-fx-text-fill:white;-fx-background-radius:8;-fx-font-size:13px;-fx-padding:10 18;-fx-cursor:hand;-fx-border-color:transparent;" />
                <Button text="✏ Update" onAction="#handleUpdate" style="-fx-background-color:#f39c12;-fx-text-fill:white;-fx-background-radius:8;-fx-font-size:13px;-fx-padding:10 18;-fx-cursor:hand;-fx-border-color:transparent;" />
                <Button text="🗑 Delete" onAction="#handleDelete" style="-fx-background-color:#e74c3c;-fx-text-fill:white;-fx-background-radius:8;-fx-font-size:13px;-fx-padding:10 18;-fx-cursor:hand;-fx-border-color:transparent;" />
            </HBox>

            <!-- Student Table -->
            <TableView fx:id="studentTable" prefHeight="195"
                style="-fx-background-color:white;-fx-background-radius:10;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);">
                <columns>
                    <TableColumn fx:id="colId"        text="Student ID" prefWidth="100" />
                    <TableColumn fx:id="colName"      text="Name"       prefWidth="145" />
                    <TableColumn fx:id="colGender"    text="Gender"     prefWidth="70" />
                    <TableColumn fx:id="colEmail"     text="Email"      prefWidth="175" />
                    <TableColumn fx:id="colPhone"     text="Phone"      prefWidth="115" />
                    <TableColumn fx:id="colClassName" text="Class"      prefWidth="200" />
                </columns>
            </TableView>

            <!-- Grades Section -->
            <VBox spacing="10" style="-fx-background-color:white;-fx-background-radius:12;
                         -fx-padding:16;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),10,0,0,3);">
                <Label fx:id="selectedStudentLabel" text="Click a student above to view their grades"
                    style="-fx-font-weight:bold;-fx-font-size:13px;-fx-text-fill:#1a1a2e;" />
                <TableView fx:id="gradeViewTable" prefHeight="150"
                    style="-fx-background-color:white;-fx-background-radius:10;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);">
                    <columns>
                        <TableColumn fx:id="colGvCourse"     text="Course ID"   prefWidth="110" />
                        <TableColumn fx:id="colGvCourseName" text="Course Name" prefWidth="200" />
                        <TableColumn fx:id="colGvGrade"      text="Grade"       prefWidth="90" />
                        <TableColumn fx:id="colGvGradePoint" text="Grade Pt"    prefWidth="100" />
                    </columns>
                </TableView>
                <HBox>
                    <Label fx:id="gpaViewLabel" text=""
                        style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:white;
                               -fx-background-color:#1a1a2e;-fx-padding:6 16;-fx-background-radius:8;" />
                </HBox>
            </VBox>

        </VBox>
    </center>
</BorderPane>
