<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane style="-fx-background-color: #f0f2f5;"
    xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="application.CourseOfferingcontroller">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: linear-gradient(to right, #1a1a2e, #0f3460);
                     -fx-padding: 0 20 0 0;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 8, 0, 0, 3);">
            <HBox alignment="CENTER" spacing="10"
                  style="-fx-background-color: #e96c50; -fx-padding: 16 24;">
                <Label text="📋" style="-fx-font-size: 20px;" />
                <Label text="Course Offering — Batch Enroll"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" />
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button text="🏠 Back to Home" onAction="#goHome"
                    style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white;
                           -fx-background-radius: 6; -fx-font-size: 13px;
                           -fx-padding: 8 16; -fx-cursor: hand; -fx-border-color: transparent;" />
        </HBox>
    </top>

    <center>
        <HBox spacing="16" style="-fx-padding: 20;">

            <!-- ══ LEFT: filter + selection panel ══ -->
            <VBox spacing="12" style="-fx-min-width: 400; -fx-max-width: 400;">

                <!-- Step 1: Filter -->
                <VBox spacing="10"
                    style="-fx-background-color: white; -fx-background-radius: 12;
                           -fx-padding: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 3);">
                    <Label text="Step 1 — Filter"
                        style="-fx-font-weight: bold; -fx-text-fill: #1a1a2e; -fx-font-size: 13px;" />

                    <VBox spacing="4">
                        <Label text="Department" style="-fx-font-size: 12px; -fx-text-fill: #555;" />
                        <ComboBox fx:id="deptCombo" prefWidth="368"
                            promptText="Select department..."
                            style="-fx-background-color: white; -fx-border-color: #d0d0d0;
                                   -fx-border-radius: 8; -fx-background-radius: 8;
                                   -fx-border-width: 1; -fx-font-size: 13px;" />
                    </VBox>

                    <HBox spacing="12">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Year Level" style="-fx-font-size: 12px; -fx-text-fill: #555;" />
                            <ComboBox fx:id="yearCombo" prefWidth="120"
                                promptText="Year..."
                                style="-fx-background-color: white; -fx-border-color: #d0d0d0;
                                       -fx-border-radius: 8; -fx-background-radius: 8;
                                       -fx-border-width: 1; -fx-font-size: 13px;" />
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Semester" style="-fx-font-size: 12px; -fx-text-fill: #555;" />
                            <TextField fx:id="semesterField" prefWidth="130"
                                promptText="Semester 1"
                                style="-fx-background-color: white; -fx-border-color: #d0d0d0;
                                       -fx-border-radius: 8; -fx-background-radius: 8;
                                       -fx-border-width: 1; -fx-padding: 8 12; -fx-font-size: 13px;" />
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Acad. Year" style="-fx-font-size: 12px; -fx-text-fill: #555;" />
                            <TextField fx:id="acadYearField" prefWidth="110"
                                promptText="2025/2026"
                                style="-fx-background-color: white; -fx-border-color: #d0d0d0;
                                       -fx-border-radius: 8; -fx-background-radius: 8;
                                       -fx-border-width: 1; -fx-padding: 8 12; -fx-font-size: 13px;" />
                        </VBox>
                    </HBox>

                    <Button text="🔍  Find Matching Sections" onAction="#handleFindSections"
                        prefWidth="368" prefHeight="38"
                        style="-fx-background-color: #2980b9; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-background-radius: 8;
                               -fx-font-size: 13px; -fx-cursor: hand; -fx-border-color: transparent;" />
                </VBox>

                <!-- Step 2: Matching Sections -->
                <VBox spacing="8"
                    style="-fx-background-color: white; -fx-background-radius: 12;
                           -fx-padding: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 3);">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Step 2 — Matching Sections"
                            style="-fx-font-weight: bold; -fx-text-fill: #1a1a2e; -fx-font-size: 13px;" />
                        <Label fx:id="sectionCountLabel" text=""
                            style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;
                                   -fx-background-color: #f0f2f5; -fx-padding: 2 8;
                                   -fx-background-radius: 10;" />
                    </HBox>
                    <ListView fx:id="sectionListView" prefHeight="130"
                        style="-fx-background-color: white; -fx-border-color: #d0d0d0;
                               -fx-border-radius: 8; -fx-background-radius: 8;" />
                    <Label text="Hold Ctrl to select/deselect individual sections"
                        style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" />
                </VBox>

                <!-- Step 3: Select Courses -->
                <VBox spacing="8"
                    style="-fx-background-color: white; -fx-background-radius: 12;
                           -fx-padding: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 3);">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Step 3 — Select Courses"
                            style="-fx-font-weight: bold; -fx-text-fill: #1a1a2e; -fx-font-size: 13px;" />
                        <Label fx:id="courseCountLabel" text=""
                            style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;
                                   -fx-background-color: #f0f2f5; -fx-padding: 2 8;
                                   -fx-background-radius: 10;" />
                    </HBox>
                    <ListView fx:id="courseListView" prefHeight="150"
                        style="-fx-background-color: white; -fx-border-color: #d0d0d0;
                               -fx-border-radius: 8; -fx-background-radius: 8;" />
                    <Label text="Hold Ctrl to select multiple courses"
                        style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" />
                </VBox>

                <!-- Status -->
                <Label fx:id="statusLabel" text="" wrapText="true"
                    style="-fx-font-size: 12px; -fx-text-fill: #1a7a4a;
                           -fx-background-color: #eafaf1; -fx-padding: 10 14;
                           -fx-background-radius: 8;" />

                <!-- Enroll Button -->
                <Button text="✔  Enroll All Students in Selected Sections + Courses"
                    onAction="#handleEnroll" prefWidth="400" prefHeight="44"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white;
                           -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-background-radius: 8; -fx-cursor: hand; -fx-border-color: transparent;" />

                <Button text="🗑 Remove Selected Offering" onAction="#handleDelete"
                    prefWidth="400"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                           -fx-background-radius: 8; -fx-font-size: 13px;
                           -fx-padding: 10 20; -fx-cursor: hand; -fx-border-color: transparent;" />

            </VBox>

            <!-- ══ RIGHT: offering table ══ -->
            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <VBox style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-padding: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 3);"
                      spacing="10" VBox.vgrow="ALWAYS">
                    <Label text="Current Offerings"
                        style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;" />

                    <TableView fx:id="offeringTable" VBox.vgrow="ALWAYS" prefHeight="640"
                        style="-fx-background-color: white; -fx-background-radius: 10;
                               -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">
                        <columns>
                            <TableColumn fx:id="colOfferingId"     text="ID"          prefWidth="48" />
                            <TableColumn fx:id="colClassDisplay"   text="Class"       prefWidth="180" />
                            <TableColumn fx:id="colCourseId"       text="Course ID"   prefWidth="88" />
                            <TableColumn fx:id="colCourseName"     text="Course Name" prefWidth="155" />
                            <TableColumn fx:id="colInstructorName" text="Instructor"  prefWidth="125" />
                            <TableColumn fx:id="colSemester"       text="Semester"    prefWidth="95" />
                            <TableColumn fx:id="colAcademicYear"   text="Year"        prefWidth="88" />
                            <TableColumn fx:id="colEnrolledCount"  text="Enrolled"    prefWidth="70" />
                        </columns>
                    </TableView>
                </VBox>
            </VBox>

        </HBox>
    </center>
</BorderPane>
